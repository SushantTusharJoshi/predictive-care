# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://pc_user:pc_local_dev_2024@localhost:5432/predictive_care
DATABASE_URL_SYNC=postgresql://pc_user:pc_local_dev_2024@localhost:5432/predictive_care

# Auth
JWT_SECRET=change-me-in-production-use-64-chars

# Groq (optional, for AI narratives)
GROQ_API_KEY=gsk_your_groq_api_key

# App
ENVIRONMENT=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# HIPAA
HIPAA_AUDIT_ENABLED=true
SESSION_TIMEOUT_MINUTES=30
